  gateway-server:
    image: bishaladhikary/gateway-server:0.0.1
    container_name: gateway-server
    ports:
      - "8080:8080"
    depends_on:
      eureka-server:
        condition: service_started

    environment:
      SPRING_CONFIG_IMPORT: optional:configserver:http://config-server:8888


  employee-service:
    image: bishaladhikary/employee-service:0.0.1
    container_name: employee-service
    ports:
      - "9030:9030"

    depends_on:
      eureka-server:
        condition: service_started
    environment:
      SPRING_CONFIG_IMPORT: optional:configserver:http://config-server:8888


  skill-service:
    image: bishaladhikary/skill-service:0.0.1
    container_name: skill-service
    ports:
      - "9040:9040"
    depends_on:
      eureka-server:
        condition: service_started
    environment:
